---
import BaseLayout from './BaseLayout.astro';
import SpecChip from '@/components/SpecChip.astro';
import { t, localizedPath, type Locale } from '@/lib/i18n';
import { adjacent, teamLabel, type ProjectMeta } from '@/lib/projects';

interface Props {
  project: ProjectMeta;
  locale: Locale;
  title: string;
  subtitle: string;
  tldr: string[];
}

const { project, locale, title, subtitle, tldr } = Astro.props;
const dict = t(locale);
const { prev, next } = adjacent(project.slug);

const tkey = (slug: string) =>
  slug === 'mems-optical-switch' ? 'mems' : slug === 'rail-to-rail-comparator' ? 'comparator' : 'opamp';
const projDict = (k: string) => (dict.projects as any)[k];
---

<BaseLayout title={`${title} · Runpeng Ma`} description={subtitle}>
  <!-- Hero strip -->
  <section class="border-b border-aqua-100 bg-gradient-to-br from-white via-aqua-50/40 to-aqua-100/40">
    <div class="container-page py-12 sm:py-16">
      <a
        href={localizedPath(locale, '/#projects')}
        class="inline-flex items-center gap-1.5 font-mono text-xs text-aqua-600 hover:text-aqua-800"
      >
        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H16a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        {dict.project_page.back}
      </a>

      <div class="mt-4 flex flex-wrap items-center gap-2 font-mono text-xs">
        <span class="font-semibold text-aqua-600">{project.date}</span>
        <span class="text-ink-soft">·</span>
        <span class="text-ink-muted">{project.course}</span>
        <span class="text-ink-soft">·</span>
        <span class="text-ink-muted">{teamLabel(project.team, locale)}</span>
      </div>

      <h1 class="mt-3 font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">{title}</h1>
      <p class="mt-2 font-display text-lg text-aqua-700 sm:text-xl">{subtitle}</p>

      <div class="mt-6 flex flex-wrap gap-2">
        {project.specs.map((s) => (
          <SpecChip>{s}</SpecChip>
        ))}
      </div>

      <!-- TL;DR -->
      <div class="mt-8 rounded-2xl border border-aqua-200 bg-white p-5 sm:p-6">
        <p class="font-display text-sm font-semibold uppercase tracking-wider text-aqua-600">
          {dict.project_page.tldr}
        </p>
        <ul class="mt-3 space-y-2">
          {tldr.map((line) => (
            <li class="flex gap-2 text-sm leading-relaxed text-ink sm:text-base">
              <span class="mt-1.5 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-aqua-400"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Body -->
  <article class="container-page py-12 sm:py-16">
    <div class="mx-auto max-w-3xl space-y-12 sm:space-y-16">
      <slot />
    </div>
  </article>

  <!-- Prev / Next -->
  <nav class="border-t border-aqua-100 bg-white">
    <div class="container-page grid grid-cols-2 gap-4 py-8">
      <div>
        {prev && (
          <a
            href={localizedPath(locale, `/projects/${prev}`)}
            class="block rounded-xl border border-aqua-100 p-4 transition-colors hover:border-aqua-300 hover:bg-aqua-50"
          >
            <p class="font-mono text-xs text-aqua-600">← {dict.project_page.prev}</p>
            <p class="mt-1 font-display font-semibold text-ink">{projDict(tkey(prev)).title}</p>
          </a>
        )}
      </div>
      <div class="text-right">
        {next && (
          <a
            href={localizedPath(locale, `/projects/${next}`)}
            class="block rounded-xl border border-aqua-100 p-4 transition-colors hover:border-aqua-300 hover:bg-aqua-50"
          >
            <p class="font-mono text-xs text-aqua-600">{dict.project_page.next} →</p>
            <p class="mt-1 font-display font-semibold text-ink">{projDict(tkey(next)).title}</p>
          </a>
        )}
      </div>
    </div>
  </nav>
</BaseLayout>
