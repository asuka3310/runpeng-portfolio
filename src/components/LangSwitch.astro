---
import { altLocalePath, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const altPath = altLocalePath(locale, pathname);
const label = locale === 'zh-TW' ? 'EN' : '中';
const ariaLabel = locale === 'zh-TW' ? 'Switch to English' : '切換到中文';
---

<a
  href={altPath}
  aria-label={ariaLabel}
  class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-aqua-200 bg-white font-display text-sm font-semibold text-aqua-700 transition-colors hover:border-aqua-400 hover:bg-aqua-50"
>
  {label}
</a>
