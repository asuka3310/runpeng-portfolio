---
import { t, localizedPath, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

// LinkedIn URL — placeholder, update before going live
const linkedinUrl = 'https://www.linkedin.com/in/runpeng-ma/';
---

<section id="contact" class="container-page py-20 sm:py-24">
  <div class="rounded-3xl border border-aqua-200 bg-gradient-to-br from-aqua-50 via-white to-aqua-100 p-8 sm:p-12 lg:p-16 reveal">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-aqua-600">
        {dict.contact.section}
      </p>
      <h2 class="mt-3 section-title">{dict.contact.section}</h2>
      <p class="mt-3 text-base text-ink-muted">{dict.contact.subtitle}</p>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={linkedinUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.27c-.97 0-1.75-.79-1.75-1.76s.78-1.76 1.75-1.76 1.75.79 1.75 1.76-.78 1.76-1.75 1.76zm13.5 12.27h-3v-5.6c0-3.37-4-3.11-4 0v5.6h-3v-11h3v1.76c1.4-2.59 7-2.78 7 2.48v6.76z" />
          </svg>
          {dict.contact.linkedin}
        </a>
        <a href={localizedPath(locale, '/resume')} class="btn-ghost">
          {dict.contact.downloadResume}
        </a>
      </div>
    </div>
  </div>
</section>
