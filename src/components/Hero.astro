---
import { t, localizedPath, type Locale } from '@/lib/i18n';
import MemsHeroSVG from './diagrams/MemsHeroSVG.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section class="relative overflow-hidden">
  <!-- Aqua gradient backdrop -->
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(ellipse 80% 60% at 70% 30%, #D1F0F2 0%, #F5FBFC 70%);"
  >
  </div>

  <div class="container-page grid gap-10 py-16 sm:py-24 lg:grid-cols-12 lg:gap-12 lg:py-28">
    <!-- Text column -->
    <div class="lg:col-span-7">
      <p class="font-mono text-sm uppercase tracking-widest text-aqua-600 reveal">
        Portfolio · 2025
      </p>

      <h1 class="mt-4 reveal">
        <span class="block font-display text-5xl font-bold leading-[1.05] tracking-tight text-ink sm:text-6xl lg:text-7xl">
          {dict.hero.name}
        </span>
        <span class="mt-2 block font-display text-2xl font-medium text-aqua-600 sm:text-3xl lg:text-4xl">
          {dict.hero.nameEn}
        </span>
      </h1>

      <p class="mt-6 max-w-xl text-lg text-ink-muted reveal sm:text-xl">
        <span class="font-medium text-ink">{dict.hero.tagline}</span>
        <span class="text-ink-soft"> · </span>
        <span class="font-mono text-base">{dict.hero.taglineEn}</span>
      </p>

      <p class="mt-4 max-w-xl text-base leading-relaxed text-ink-muted reveal">
        {dict.hero.intro}
      </p>

      <div class="mt-8 flex flex-wrap gap-3 reveal">
        <a href={localizedPath(locale, '/#projects')} class="btn-primary">
          {dict.hero.cta1}
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H4a1 1 0 110-2h8.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href={localizedPath(locale, '/resume')} class="btn-ghost">
          {dict.hero.cta2}
        </a>
        <a
          href="#contact"
          class="btn-ghost"
        >
          {dict.hero.cta3}
        </a>
      </div>
    </div>

    <!-- Visual column -->
    <div class="lg:col-span-5">
      <div class="relative aspect-[3/2] w-full max-w-md mx-auto lg:max-w-none">
        <div class="absolute inset-0 rounded-3xl bg-white/40 backdrop-blur-sm border border-aqua-100"></div>
        <div class="absolute inset-0 p-4">
          <MemsHeroSVG />
        </div>
      </div>
      <p class="mt-3 text-center font-mono text-xs text-ink-soft">
        Master's thesis: MEMS Optical Switch · Electrostatic actuation
      </p>
    </div>
  </div>
</section>
