---
// 6-layer MEMS optical switch cross-section, labeled.
---

<figure class="w-full">
  <svg viewBox="0 0 720 480" xmlns="http://www.w3.org/2000/svg" class="w-full" role="img" aria-labelledby="mems-stack-title">
    <title id="mems-stack-title">MEMS Optical Switch · 6-Layer Cross-Section</title>

    <defs>
      <pattern id="hatch" width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
        <line x1="0" y1="0" x2="0" y2="6" stroke="#5C7479" stroke-width="0.6" opacity="0.4" />
      </pattern>
      <linearGradient id="metal-au" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#E5C97A" />
        <stop offset="100%" stop-color="#B89A4F" />
      </linearGradient>
      <linearGradient id="metal-pt" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#C9D1D5" />
        <stop offset="100%" stop-color="#7E8A8F" />
      </linearGradient>
    </defs>

    <!-- P-substrate (bottom) -->
    <g>
      <rect x="80" y="380" width="560" height="60" fill="url(#hatch)" stroke="#5C7479" stroke-width="1" />
      <rect x="80" y="380" width="560" height="60" fill="#0F2A2D" opacity="0.04" />
    </g>

    <!-- Insulating SiO2 layer -->
    <rect x="80" y="365" width="560" height="15" fill="#D6ECEE" stroke="#2A9098" stroke-width="0.8" />

    <!-- Bottom electrode (Au, split) -->
    <rect x="120" y="350" width="220" height="15" fill="url(#metal-au)" stroke="#8B6F2F" stroke-width="0.8" />
    <rect x="380" y="350" width="220" height="15" fill="url(#metal-au)" stroke="#8B6F2F" stroke-width="0.8" />
    <line x1="350" y1="345" x2="350" y2="370" stroke="#8B6F2F" stroke-width="0.6" stroke-dasharray="2 2" />

    <!-- Floating polysilicon (with etched gap for mirror cavity) -->
    <rect x="80" y="270" width="160" height="80" fill="#A8E2E6" stroke="#2A9098" stroke-width="0.8" />
    <rect x="480" y="270" width="160" height="80" fill="#A8E2E6" stroke="#2A9098" stroke-width="0.8" />
    <text x="240" y="312" font-family="JetBrains Mono, monospace" font-size="11" fill="#2A9098">cavity (air)</text>
    <text x="240" y="328" font-family="JetBrains Mono, monospace" font-size="11" fill="#5C7479">g₀ = 44 μm</text>

    <!-- Springs (4 serpentine, schematic) -->
    <g stroke="#2A9098" stroke-width="2" fill="none" stroke-linecap="round">
      <path d="M150 240 L150 250 L130 250 L130 260 L150 260 L150 270" />
      <path d="M570 240 L570 250 L590 250 L590 260 L570 260 L570 270" />
    </g>

    <!-- SiO2 micromirror layer (tilted slightly to suggest rotation) -->
    <g transform="rotate(-2 360 230)">
      <rect x="160" y="220" width="400" height="20" fill="#FFFFFF" stroke="#2A9098" stroke-width="1.5" />

      <!-- Top electrodes (4 Pt) -->
      <rect x="190" y="208" width="70" height="12" fill="url(#metal-pt)" stroke="#5C7479" stroke-width="0.6" />
      <rect x="280" y="208" width="70" height="12" fill="url(#metal-pt)" stroke="#5C7479" stroke-width="0.6" />
      <rect x="370" y="208" width="70" height="12" fill="url(#metal-pt)" stroke="#5C7479" stroke-width="0.6" />
      <rect x="460" y="208" width="70" height="12" fill="url(#metal-pt)" stroke="#5C7479" stroke-width="0.6" />
    </g>

    <!-- Light beam path -->
    <g stroke="#3FA89B" stroke-width="1.6" fill="none" stroke-dasharray="6 4">
      <path d="M30 80 L360 230" />
      <path d="M360 230 L690 80" />
    </g>
    <text x="40" y="76" font-family="JetBrains Mono, monospace" font-size="11" fill="#3FA89B" font-weight="600">λ_in</text>
    <text x="680" y="76" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="11" fill="#3FA89B" font-weight="600">λ_out</text>

    <!-- Voltage labels -->
    <g font-family="JetBrains Mono, monospace" font-size="10" fill="#2A9098">
      <text x="230" y="345" text-anchor="middle" font-weight="600">+V</text>
      <text x="490" y="345" text-anchor="middle" font-weight="600">−V</text>
    </g>

    <!-- Layer labels (right side) -->
    <g font-family="Inter, sans-serif" font-size="11" fill="#0F2A2D">
      <line x1="640" y1="214" x2="700" y2="180" stroke="#5C7479" stroke-width="0.6" />
      <text x="700" y="178">Pt top electrodes</text>

      <line x1="640" y1="230" x2="700" y2="200" stroke="#5C7479" stroke-width="0.6" />
      <text x="700" y="198">SiO₂ micromirror (5 μm)</text>

      <line x1="240" y1="240" x2="120" y2="120" stroke="#5C7479" stroke-width="0.6" />
      <text x="120" y="118" text-anchor="end">SiO₂ serpentine springs (×4)</text>

      <line x1="650" y1="290" x2="700" y2="280" stroke="#5C7479" stroke-width="0.6" />
      <text x="700" y="278">Floating polysilicon</text>

      <line x1="650" y1="357" x2="700" y2="340" stroke="#5C7479" stroke-width="0.6" />
      <text x="700" y="338">Au bottom electrode (split)</text>

      <line x1="650" y1="372" x2="700" y2="380" stroke="#5C7479" stroke-width="0.6" />
      <text x="700" y="382">Insulating SiO₂</text>

      <line x1="650" y1="410" x2="700" y2="425" stroke="#5C7479" stroke-width="0.6" />
      <text x="700" y="427">P-substrate (Si)</text>
    </g>

    <!-- Rotation indicator -->
    <g transform="translate(360 230)">
      <path d="M 0 -50 A 50 50 0 0 1 26 -42" stroke="#5EBDC4" stroke-width="1.5" fill="none" />
      <path d="M 26 -42 L 22 -38 L 30 -38 Z" fill="#5EBDC4" />
      <text x="35" y="-45" font-family="JetBrains Mono, monospace" font-size="11" fill="#2A9098" font-weight="600">θ ≈ 2.5°</text>
    </g>
  </svg>
  <figcaption class="mt-3 font-mono text-xs text-ink-soft">
    Fig. 1 — Cross-section of the MEMS optical switch. Six layers from substrate to top electrode; differential drive via split bottom electrodes; 4 SiO₂ serpentine springs replace traditional torsion.
  </figcaption>
</figure>
