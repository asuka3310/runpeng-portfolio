---
import { t, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section class="container-page py-16 sm:py-20">
  <div class="reveal mb-10 max-w-2xl">
    <p class="font-mono text-xs uppercase tracking-widest text-aqua-600">
      {dict.education.section}
    </p>
    <h2 class="mt-2 section-title">{dict.education.section}</h2>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div class="reveal rounded-2xl border border-aqua-200 bg-white p-6 sm:p-7">
      <p class="font-mono text-xs text-aqua-600">{dict.education.unsw.period}</p>
      <h3 class="mt-2 font-display text-xl font-semibold text-ink">
        {dict.education.unsw.school}
      </h3>
      <p class="mt-1 text-sm text-ink-muted">{dict.education.unsw.degree}</p>
    </div>

    <div class="reveal rounded-2xl border border-aqua-100 bg-aqua-50/30 p-6 sm:p-7">
      <p class="font-mono text-xs text-aqua-600">{dict.education.sjtu.period}</p>
      <h3 class="mt-2 font-display text-xl font-semibold text-ink">
        {dict.education.sjtu.school}
      </h3>
      <p class="mt-1 text-sm text-ink-muted">{dict.education.sjtu.degree}</p>
    </div>
  </div>
</section>
