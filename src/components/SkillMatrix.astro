---
import { t, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const isZh = locale === 'zh-TW';

const groups = [
  {
    title: isZh ? 'Cadence 工具鏈（最熟）' : 'Cadence Toolchain (Strongest)',
    highlight: true,
    items: isZh
      ? ['Virtuoso Schematic Editor', 'Virtuoso Layout Suite', 'Spectre / Spectre RF', 'ADE-L / ADE-XL', 'Calibre DRC / LVS', 'FreePDK 45 nm PDK']
      : ['Virtuoso Schematic Editor', 'Virtuoso Layout Suite', 'Spectre / Spectre RF', 'ADE-L / ADE-XL', 'Calibre DRC / LVS', 'FreePDK 45 nm PDK'],
  },
  {
    title: isZh ? 'MEMS / 物理建模' : 'MEMS / Physical Modeling',
    highlight: false,
    items: isZh
      ? ['COMSOL Multiphysics', '有限元分析 (FEA)', '靜電致動模型', '頻率響應分析', '結構共振模擬']
      : ['COMSOL Multiphysics', 'Finite Element Analysis', 'Electrostatic Actuation', 'Frequency Response', 'Resonance Simulation'],
  },
  {
    title: isZh ? '訊號調理 & 系統整合' : 'Signal Conditioning & Systems',
    highlight: false,
    items: isZh
      ? ['多模態可重構電路 (R/I/C/V)', '電荷放大電路', 'A/D 採集 (PXI-6289)', 'STM32 韌體', '藍牙無線傳輸 (HC-05)', 'MXene 柔性感測器']
      : ['Multi-modal Reconfigurable (R/I/C/V)', 'Charge Amplifier', 'A/D Acquisition (PXI-6289)', 'STM32 Firmware', 'Bluetooth Wireless (HC-05)', 'MXene Flexible Sensors'],
  },
  {
    title: isZh ? '類比電路設計方法論' : 'Analog Design Methodology',
    highlight: false,
    items: isZh
      ? ['電晶體層級設計', 'Monte Carlo / Corner', 'Folded Cascode', '兩階運算放大器', 'Pull-in 風險評估', 'Wafer 鍵合製程']
      : ['Transistor-Level Design', 'Monte Carlo / Corner', 'Folded Cascode', 'Two-Stage Op-Amp', 'Pull-in Risk Evaluation', 'Wafer Bonding'],
  },
];
---

<section class="container-page py-16 sm:py-20">
  <div class="reveal mb-10 max-w-2xl">
    <p class="font-mono text-xs uppercase tracking-widest text-aqua-600">
      {dict.skills.section}
    </p>
    <h2 class="mt-2 section-title">{dict.skills.section}</h2>
    <p class="section-subtitle">{dict.skills.subtitle}</p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-2 lg:gap-6">
    {groups.map((g) => (
      <div class={`reveal rounded-2xl border p-6 sm:p-7 ${g.highlight ? 'border-aqua-400 bg-gradient-to-br from-white to-aqua-50 shadow-sm' : 'border-aqua-100 bg-white'}`}>
        <h3 class={`font-display text-lg font-semibold ${g.highlight ? 'text-aqua-700' : 'text-aqua-700'}`}>
          {g.title}
        </h3>
        <ul class="mt-4 grid gap-2 sm:grid-cols-2">
          {g.items.map((item) => (
            <li class="flex items-start gap-2 text-sm text-ink-muted">
              <span class={`mt-1.5 inline-block h-1 w-1 flex-shrink-0 rounded-full ${g.highlight ? 'bg-aqua-500' : 'bg-aqua-400'}`}></span>
              <span class="font-mono text-[13px]">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
