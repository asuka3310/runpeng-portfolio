---
import { t, localizedPath, type Locale } from '@/lib/i18n';
import { teamLabel, type ProjectMeta } from '@/lib/projects';
import SpecChip from './SpecChip.astro';

interface Props {
  project: ProjectMeta;
  locale: Locale;
  bigCard?: boolean;
}

const { project, locale, bigCard = false } = Astro.props;
const dict = t(locale);

// Project slug → translation key in dict.projects
const tkey = project.slug === 'mems-optical-switch'
  ? 'mems'
  : project.slug === 'rail-to-rail-comparator'
    ? 'comparator'
    : 'opamp';

const projDict = (dict.projects as any)[tkey];
const href = localizedPath(locale, `/projects/${project.slug}`);

const cardCls = bigCard
  ? 'group relative flex flex-col overflow-hidden rounded-3xl border border-aqua-200 bg-gradient-to-br from-white via-aqua-50 to-aqua-100 p-7 transition-all hover:border-aqua-400 hover:shadow-lg hover:-translate-y-1 sm:p-8 lg:p-10'
  : 'group relative flex flex-col overflow-hidden rounded-3xl border border-aqua-200 bg-white p-6 transition-all hover:border-aqua-400 hover:shadow-md hover:-translate-y-1 sm:p-7';
---

<a href={href} class={cardCls}>
  <div class="flex flex-wrap items-center gap-2 font-mono text-xs">
    <span class="font-semibold text-aqua-600">{project.date}</span>
    <span class="text-ink-soft">·</span>
    <span class="text-ink-muted">{project.course}</span>
    <span class="text-ink-soft">·</span>
    <span class="text-ink-muted">{teamLabel(project.team, locale)}</span>
  </div>

  <h3 class={`mt-4 font-display font-bold text-ink leading-tight ${bigCard ? 'text-3xl sm:text-4xl' : 'text-2xl'}`}>
    {projDict.title}
  </h3>
  <p class={`mt-1 font-display text-aqua-600 ${bigCard ? 'text-lg' : 'text-base'}`}>
    {projDict.subtitle}
  </p>

  <p class={`mt-4 leading-relaxed text-ink-muted ${bigCard ? 'text-base sm:text-lg' : 'text-sm'}`}>
    {projDict.summary}
  </p>

  <div class="mt-5 flex flex-wrap gap-2">
    {project.specs.map((s) => (
      <SpecChip>{s}</SpecChip>
    ))}
  </div>

  <div class="mt-auto pt-6">
    <span class="inline-flex items-center gap-1.5 font-display font-semibold text-aqua-600 transition-transform group-hover:translate-x-1">
      {dict.projects.viewDetails}
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H4a1 1 0 110-2h8.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </span>
  </div>

  <!-- Decorative big number -->
  {bigCard && (
    <div
      class="pointer-events-none absolute -right-4 -bottom-6 select-none font-display text-[10rem] font-bold leading-none text-aqua-100 opacity-60"
      aria-hidden="true"
    >
      01
    </div>
  )}
</a>
