---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocaleFromUrl, t } from '@/lib/i18n';

const locale = getLocaleFromUrl(Astro.url);
const dict = t(locale);
const isZh = locale === 'zh-TW';
---

<BaseLayout title="Resume · Runpeng Ma">
  <section class="container-page py-12 sm:py-16">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between reveal">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-aqua-600">{dict.nav.resume}</p>
          <h1 class="mt-2 font-display text-3xl font-bold text-ink sm:text-4xl">
            {isZh ? '完整履歷' : 'Full Resume'}
          </h1>
          <p class="mt-2 text-sm text-ink-muted">
            {isZh
              ? '47 頁完整版（含碩士論文 portfolio 與專案 contributions）'
              : '47-page full version (includes thesis portfolio and project contributions)'}
          </p>
        </div>
        <a href="/resume.pdf" download="Runpeng_Ma_Resume.pdf" class="btn-primary">
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
          {isZh ? '下載 PDF' : 'Download PDF'}
        </a>
      </div>

      <div class="mt-8 overflow-hidden rounded-3xl border border-aqua-200 bg-white reveal">
        <object data="/resume.pdf#view=FitH" type="application/pdf" class="block w-full" style="height: 90vh; min-height: 600px;">
          <div class="p-12 text-center text-ink-muted">
            <p>{isZh ? '無法在此瀏覽器內嵌 PDF。' : 'Cannot embed PDF in this browser.'}</p>
            <p class="mt-2">
              <a href="/resume.pdf" class="text-aqua-600 underline">
                {isZh ? '請點此下載' : 'Click to download'}
              </a>
            </p>
          </div>
        </object>
      </div>
    </div>
  </section>
</BaseLayout>
